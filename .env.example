# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cybercafe

# Security
SECRET_KEY=your-secret-key-change-in-production

# Server
HOST=0.0.0.0
PORT=8000

# CORS
CORS_ORIGINS=["http://localhost:7842","http://localhost:8080"]

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Deployment
DEPLOYMENT_MODE=local_only

# Sync
SYNC_ENABLED=true
SYNC_INTERVAL_MINUTES=30
GLOBAL_SERVER_URL=

# Branch
BRANCH_ID=1

# Filtering
DNS_BLOCKING=true
PROCESS_BLOCKING=false
URL_FILTERING=false

# Payment - Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Payment - Konga Pay
KONGA_PAY_MERCHANT_ID=
